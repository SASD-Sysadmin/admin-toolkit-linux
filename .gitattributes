# Keep repository text files predictable across Windows, WSL and Linux.
* text=auto eol=lf

*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.tsv text eol=lf
Makefile text eol=lf

# Do not normalize binary artifacts if they are added later.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
